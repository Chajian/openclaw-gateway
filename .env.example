# ===== Gateway =====
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_CHAT_ID=1156180724

# Feishu / Lark（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# Gateway 端口
GATEWAY_PORT=3000

# ===== Key Orchestrator =====
KEYHUB_MASTER_KEY=your-master-key-here

# Cron: 每天 09:10 (秒 分 时 日 月 周)
CRON_SCHEDULE=0 10 9 * * *

# ===== LinuxDo Monitor =====
MONITOR_INTERVAL_MS=600000
