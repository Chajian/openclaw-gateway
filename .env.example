# ===== OpenClaw 主程序 =====
# 镜像来源（本地构建用 openclaw:local，远程用 ghcr.io/chajian/openclaw:latest）
OPENCLAW_IMAGE=openclaw:local

# Gateway 认证 Token（留空则不启用认证）
OPENCLAW_GATEWAY_TOKEN=

# Gateway 绑定地址（lan = 0.0.0.0，loopback = 127.0.0.1）
OPENCLAW_GATEWAY_BIND=lan

# Gateway 端口
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# ===== LLM API Keys =====
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1

# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_CHAT_ID=1156180724
# 订阅码（用户私聊机器人发送 /sub <订阅码>）
SUB_CODE=change-this-sub-code

# ===== 飞书 / Lark（可选）=====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ===== Key Orchestrator =====
KEYHUB_MASTER_KEY=your-master-key-here

# Cron: 每天 09:10（秒 分 时 日 月 周）
CRON_SCHEDULE=0 10 9 * * *

# ===== LinuxDo Monitor =====
MONITOR_INTERVAL_MS=600000
# 推送模式：auto(有订阅发订阅，无订阅发固定chat) | fixed | subscribers | both
PUSH_MODE=auto
SUBSCRIBERS_FILE=/data/subscribers.json
TELEGRAM_POLL_INTERVAL_MS=5000
DATA_DIR=/data
