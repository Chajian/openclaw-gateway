{
  "name": "@openclaw/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw core: encrypted store, adapter registry, plugin host, sync/export cycles.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./lib/*": "./src/lib/*",
    "./adapters/*": "./src/adapters/*"
  },
  "scripts": {
    "dev:sync": "tsx src/sync-keys.ts",
    "dev:import:token": "tsx src/import-secret.ts",
    "dev:auto": "tsx src/auto-cycle.ts",
    "dev:stable": "tsx src/stable-cycle.ts",
    "dev:export:env": "tsx src/export-openclaw-env.ts",
    "dev:export:json": "tsx src/export-openclaw-json.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "tslog": "^4.10.2",
    "zod": "^3.25.76"
  }
}
